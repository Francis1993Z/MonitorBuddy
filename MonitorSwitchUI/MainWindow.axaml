<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="320"
        xmlns:local="clr-namespace:MonitorSwitch"
        x:Class="MonitorSwitch.MainWindow"
        Title="Monitor Switch"
        Width="620" Height="700"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Background="Transparent">

    <Border CornerRadius="16"
            Background="#1E1E2E"
            BorderBrush="#313244"
            BorderThickness="1"
            Padding="24"
            ClipToBounds="True">

        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

            <!-- Titre -->
            <TextBlock Grid.Row="0"
                       Text="Monitor Switch"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#CDD6F4"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,20"/>

            <!-- Panneau diagnostic : écrans détectés (scrollable) -->
            <Border Grid.Row="1"
                    Background="#181825"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,0,16"
                    MaxHeight="350">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="DiagText"
                               Text="Détection en cours..."
                               FontSize="10.5"
                               FontFamily="Consolas, monospace"
                               Foreground="#A6ADC8"
                               TextWrapping="NoWrap"/>
                </ScrollViewer>
            </Border>

            <!-- Panneau configuration layout Bureau -->
            <Border Grid.Row="2"
                    Background="#181825"
                    CornerRadius="8"
                    Padding="10"
                    Margin="0,0,0,16">
                <StackPanel Spacing="8">
                    <TextBlock Text="Configuration Bureau (gauche → droite)"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#CDD6F4"/>

                    <!-- Liste des écrans avec boutons -->
                    <ItemsControl x:Name="LayoutList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="local:LayoutItem">
                                <Border Background="#313244" CornerRadius="6" Padding="8,6" Margin="0,2">
                                    <Grid ColumnDefinitions="Auto,*,Auto,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Position}"
                                                   FontSize="12" FontWeight="Bold"
                                                   Foreground="#89B4FA"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   FontSize="12"
                                                   Foreground="#CDD6F4"
                                                   VerticalAlignment="Center"/>
                                        <Button Grid.Column="2"
                                                Tag="{Binding Name}"
                                                Click="OnClickSetPrimary"
                                                Background="Transparent"
                                                Foreground="{Binding PrimaryColor}"
                                                FontSize="16"
                                                Padding="4,2"
                                                Cursor="Hand"
                                                ToolTip.Tip="Définir comme principal"
                                                Content="★"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="2">
                                            <Button Tag="{Binding Name}"
                                                    Click="OnClickMoveLeft"
                                                    Background="Transparent"
                                                    Foreground="#A6ADC8"
                                                    FontSize="14"
                                                    Padding="4,2"
                                                    Cursor="Hand"
                                                    Content="◀"/>
                                            <Button Tag="{Binding Name}"
                                                    Click="OnClickMoveRight"
                                                    Background="Transparent"
                                                    Foreground="#A6ADC8"
                                                    FontSize="14"
                                                    Padding="4,2"
                                                    Cursor="Hand"
                                                    Content="▶"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Boutons -->
            <StackPanel Grid.Row="3"
                        Spacing="16"
                        VerticalAlignment="Center">

                <!-- Bouton Mode TV -->
                <Button x:Name="BtnModeTV"
                        Click="OnClickModeTV"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Height="56"
                        CornerRadius="12"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        FontSize="16" FontWeight="SemiBold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="📺" FontSize="22" VerticalAlignment="Center"/>
                        <TextBlock Text="Mode TV" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Bouton Mode Bureau -->
                <Button x:Name="BtnModeBureau"
                        Click="OnClickModeBureau"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Height="56"
                        CornerRadius="12"
                        Background="#45475A"
                        Foreground="#CDD6F4"
                        FontSize="16" FontWeight="SemiBold"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="🖥️" FontSize="22" VerticalAlignment="Center"/>
                        <TextBlock Text="Mode Bureau" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>

            <!-- Barre de statut + Quitter -->
            <Grid Grid.Row="4" Margin="0,16,0,0">
                <TextBlock x:Name="StatusText"
                           Text="Prêt"
                           FontSize="12"
                           Foreground="#6C7086"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Button Click="OnClickQuitter"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="#F38BA8"
                        Foreground="#1E1E2E"
                        CornerRadius="8"
                        Padding="14,6"
                        FontSize="12" FontWeight="SemiBold"
                        Cursor="Hand"
                        Content="✕  Quitter"/>
            </Grid>

        </Grid>
    </Border>
</Window>
